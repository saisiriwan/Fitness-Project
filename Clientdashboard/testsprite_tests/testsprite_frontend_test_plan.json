  {
    "id": "TC001",
    "title": "View Today schedule cards and open session details modal",
    "description": "Verifies that an authenticated user can view Today schedule cards and open a session details modal showing exercises and time.",
    "category": "Dashboard Schedule",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"Today\" tab"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Schedule cards list\" is visible"
      },
      {
        "type": "action",
        "description": "Click a schedule card"
      }
    ]
  },
