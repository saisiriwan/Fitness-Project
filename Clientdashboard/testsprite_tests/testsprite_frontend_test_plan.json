  {
    "id": "TC007",
    "title": "Save valid set values and completion status inside the session modal",
    "description": "Verifies a trainer can edit reps/weight/RPE, toggle completion, save, and see updated values within the open session modal.",
    "category": "Session Logging",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on a session in the schedule to open the session modal"
      },
      {
        "type": "action",
        "description": "Expand exercise details"
      },
      {
        "type": "action",
        "description": "Fill \"10\" into the reps field"
      },
      {
        "type": "action",
        "description": "Fill \"50\" into the weight field"
      },
      {
        "type": "action",
        "description": "Fill \"7\" into the RPE field"
      },
      {
        "type": "action",
        "description": "Toggle completion status for the set"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"10\" is visible in the reps value area for that set in the session modal"
      },
      {
        "type": "assertion",
        "description": "Verify text \"50\" is visible in the weight value area for that set in the session modal"
      },
      {
        "type": "assertion",
        "description": "Verify text \"7\" is visible in the RPE value area for that set in the session modal"
      }
    ]
  },
