# Backend Server Environment Variables

# Database
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres

# Server Config
API_PORT=8080
API_TOKEN=your_internal_api_token
JWT_SECRET=your_long_jwt_secret_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=https://your-production-backend-url/auth/google/callback

# CORS and Domains
CORS_ALLOWED_ORIGINS=https://client.yourdomain.com,https://trainer.yourdomain.com
FRONTEND_CLIENT_URL=https://client.yourdomain.com
FRONTEND_TRAINER_URL=https://trainer.yourdomain.com/dashboard
COOKIE_DOMAIN=.yourdomain.com
